# ── EDMA L2 Environment Configuration ────────────────────────────────────────
#
# Copy this file to .env and fill in your values.
# For the local devnet, the pre-funded dev account key is already set below.

# ── Devnet (OP Stack local) ──────────────────────────────────────────────────
# Pre-funded account from the OP Stack devnet (Hardhat account #0)
# Address: 0xf39Fd6e51aad88F6F4ce6aB8827279cffFb92266
DEPLOYER_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# L1 RPC (devnet)
L1_RPC_URL=http://127.0.0.1:8545

# L2 RPC (EDMA devnet)
L2_RPC_URL=http://127.0.0.1:9545

# ── Testnet / Mainnet ────────────────────────────────────────────────────────
# DEPLOYER_PRIVATE_KEY=<your-deployer-key>
# SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/<your-key>
# EDMA_MAINNET_RPC_URL=https://rpc.edma.app

# ── Misc ─────────────────────────────────────────────────────────────────────
REPORT_GAS=false
